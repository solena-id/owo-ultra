# ╔══════════════════════════════════════════════════════════════════╗
# ║            OwO Pro Farmer VIP — CẤU HÌNH HỆ THỐNG                ║
# ║                                                                  ║
# ║   true = BẬT (Cho phép)   |   false = TẮT (Không cho phép)       ║
# ║   Khởi động lại phần mềm để áp dụng mọi thay đổi.                ║
# ╚══════════════════════════════════════════════════════════════════╝

# --- 1. BẢN QUYỀN ---
LICENSE_KEY=

# --- 2. HỆ THỐNG CAPTCHA ---
CAPTCHA_API_KEY=
USE_AUTO_CAPTCHA_LINK=true
USE_AUTO_CAPTCHA_IMAGE=true
CAPTCHA_CONCURRENCY=2
CHROME_PATH=

# --- 3. THÔNG BÁO WEBHOOK ---
NOTIFY_BOT_TOKEN=
ADMIN_ID=
WEBHOOK_URL=
LOG_WEBHOOK_URL=

# --- 4. CHẾ ĐỘ FARM CƠ BẢN ---
# Chế độ mô phỏng ngủ thật của người dùng (nghỉ 6-8 tiếng mỗi ngày)
SLEEP_CYCLE=true

# Tự động gửi lệnh "owo hunt" và "owo battle"
AUTO_HUNT=true

# Tự động gửi lệnh "owo pray". Nếu tắt AUTO_PRAY và bật AUTO_CURSE, bot sẽ gửi "owo curse"
AUTO_PRAY=true
AUTO_CURSE=false
# Danh sách ID người dùng để pray/curse (cách nhau bằng dấu phẩy). Để trống sẽ pray/curse cho bản thân.
CURSE_PRAY_TARGETS=

# Tự động nhận phần thưởng hằng ngày "owo daily"
AUTO_DAILY=true

# --- 5. AUTO HUNTBOT ---
# Tự động cử Huntbot đi săn và thu hoạch
AUTO_HUNTBOT=true

# Tự động nâng cấp Huntbot bằng animal essence (với các acc có vip)
AUTO_HUNTBOT_UPGRADE=true
# Thứ tự ưu tiên nâng cấp chỉ số của huntbot
HUNTBOT_UPGRADE_PRIORITY=efficiency, gain, duration, cost, experience, radar
# Giới hạn cấp độ tối đa khi nâng cấp (tránh dùng hết essence)
HUNTBOT_UPGRADE_MAX_LEVEL=1000

# --- 6. NGỌC, TÚI ĐỒ & VẬT PHẨM ---
# Tự động trang bị ngọc (gems) khi đi săn
AUTO_USE_GEMS=true
# Các loại ngọc cụ thể muốn sử dụng
CUSTOM_GEMS=51,52,53,54,55,56,57,65,66,67,68,69,70,71,72,73,74,75,76,77,78

# Tự động bán thú/vật phẩm khi đầy kho hoặc khi hết tiền (để chống kẹt tiền)
AUTO_SELL=true
# Loại thú để bán (ví dụ: all, common, uncommon, ... trừ mythic, fabled, gem)
SELL_TYPE=all

# Tự động hiến tế (sacrifice) thú để lấy animal essence nâng cấp huntbot
AUTO_SACRIFICE=true
# Loại thú để hiến tế
SACRIFICE_TYPE=all

# Tự động mở hộp quà Weapon Crate và Lootbox ngay khi nhận được
AUTO_OPEN_BOXES=true

# --- 7. CÁC TÍNH NĂNG PHỤ TRỢ (TỰ ĐỘNG KHÁC) ---
# Tự động trả lời ngụy trang ("chống ping") khi có ai đó tag bot vào kênh chat
AUTO_REPLY=false

# Tự động làm nhiệm vụ (Quest) thông minh khi được yêu cầu
AUTO_QUEST=false

# Tự động báo danh và nhận thẻ bài (Cookie)
AUTO_COOKIE=false
# Nhập ID của tài khoản chính để gửi cookie, nếu để trống sẽ tự random
COOKIE_TARGET_ID=

# Tự động tham gia đánh Guild Boss khi ai đó spawn boss
AUTO_BOSS=false
# Tỉ lệ tham gia đánh Boss (từ 1 đến 100). Ví dụ 100 là luôn tham gia
BOSS_JOIN_CHANCE=100

# Tự động tham gia Giveaway (Thả cảm xúc vào tin nhắn)
AUTO_GIVEAWAY=false
# Danh sách ID các channel chứa giveaway mà bạn muốn bot nhắm đến (cách nhau dấu phẩy)
GIVEAWAY_CHANNELS=

# Tự động đổi kênh (Channel Switch) thi thoảng ngẫu nhiên (chống ban)
AUTO_CHANNEL_SWITCH=false

# Tự động tạo Battle Team với các thú mạnh nhất (Smart Zoo) khi không có team hoặc chưa set team
AUTO_SMART_ZOO=true

# Tự động bấm Accept Rules khi bị OwO bắt buộc chấp nhận điều khoản để tiếp tục chơi
AUTO_ACCEPT_RULES=true

# --- 8. TÍNH NĂNG MINI GAME (ĐÁNH BẠC / LEVEL) ---
AUTO_GAMBLE_CF=false
AUTO_GAMBLE_CF_AMOUNT=1
AUTO_GAMBLE_CF_SIDE=h
AUTO_GAMBLE_SLOTS=false
AUTO_GAMBLE_SLOTS_AMOUNT=1
AUTO_LEVEL_QUOTES=false

# --- 9. RPP & SHOP MỞ RỘNG ---
AUTO_RPP=false
RPP_COMMANDS=run,pup,piku
RPP_INTERVAL=60

AUTO_SHOP=false
SHOP_ITEMS=
SHOP_INTERVAL=3600