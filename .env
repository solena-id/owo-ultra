# ================================================================
# OwO Pro Farmer VIP — CONFIG (true=ON/BẬT | false=OFF/TẮT)
# Restart tool after changes / Khởi động lại tool sau khi sửa
# ================================================================

# --- 1. LICENSE / BẢN QUYỀN ---
LICENSE_KEY=

# --- 2. CAPTCHA ---
CAPTCHA_API_KEY=
USE_AUTO_CAPTCHA_LINK=true             # Solve hCaptcha link / Giải captcha link
USE_AUTO_CAPTCHA_IMAGE=true            # Solve image captcha / Giải captcha ảnh
CAPTCHA_CONCURRENCY=2                  # Parallel solvers / Số luồng song song (tốn RAM)
CHROME_PATH=                           # Blank=auto-detect / Trống=tự tìm

# --- 3. NOTIFICATIONS / THÔNG BÁO ---
NOTIFY_BOT_TOKEN=
ADMIN_ID=
WEBHOOK_URL=
LOG_WEBHOOK_URL=

# --- 4. HUMANIZATION / CHỐNG BAN ---
SLEEP_CYCLE=false                      # Sleep 6-8h/day / Ngủ 6-8h mỗi ngày
TYPING_SIMULATION=false                # Simulate typing / Mô phỏng gõ phím

# --- 5. CORE FARMING / FARM CƠ BẢN ---
AUTO_HUNT=true                         # owo hunt+battle 16-21s / Mỗi 16-21 giây
AUTO_PRAY=true                         # owo pray 5-6min / Mỗi 5-6 phút
AUTO_CURSE=false                       # owo curse instead/also / Curse thay/kèm pray
CURSE_PRAY_TARGETS=                    # IDs comma / ID dấu phẩy (trống=self)
AUTO_DAILY=true                        # owo daily 24h
AUTO_SYNC_CASH=false                   # Sync balance 12-18min / Đồng bộ số dư

# --- 6. HUNTBOT ---
AUTO_HUNTBOT=true                      # owo autohunt 24h + harvest / Săn + thu hoạch
AUTO_HUNTBOT_UPGRADE=true              # Auto-upgrade traits / Tự nâng cấp trait
HUNTBOT_UPGRADE_PRIORITY=efficiency, gain, duration, cost, experience, radar
HUNTBOT_UPGRADE_MAX_LEVEL=1000         # Cap per trait (1000=none) / Trần mỗi trait

# --- 7. GEMS & INVENTORY / NGỌC & TÚI ---
# Ranks: c=common u=uncommon r=rare e=epic m=mythic l=legendary f=fabled g=gem
# ⚠️ DO NOT use "all" — will sell fabled! / KHÔNG dùng "all" — mất fabled!
AUTO_USE_GEMS=true                     # Auto-equip gems / Tự trang bị ngọc
CUSTOM_GEMS=51,52,53,54,55,56,57,65,66,67,68,69,70,71,72,73,74,75,76,77,78
AUTO_SELL=true                         # Auto-sell 20-30min / Bán mỗi 20-30 phút
SELL_TYPE=all                          # Ranks to sell / Rank bán
AUTO_SACRIFICE=true                    # Auto-sac 50-70min / Hiến tế mỗi 50-70 phút
SACRIFICE_TYPE=all                     # Ranks to sac / Rank hiến tế
AUTO_OPEN_BOXES=true                   # Open crates/lootboxes / Mở hộp

# --- 8. EXTRAS / TÍNH NĂNG PHỤ ---
AUTO_REPLY=false                       # Cover reply on ping / Trả lời khi bị ping
AUTO_QUEST=false                       # Reroll bad quests / Reroll quest xấu
AUTO_COOKIE=false                      # owo cookie daily
COOKIE_TARGET_ID=                      # Cookie target (blank=random) / ID nhận
AUTO_BOSS=false                        # Auto-join guild boss / Tự đánh boss
BOSS_JOIN_CHANCE=100                   # Join probability % / Tỉ lệ tham gia %
AUTO_GIVEAWAY=false                    # Auto-join giveaways / Tự tham gia
GIVEAWAY_CHANNELS=                     # Channel IDs comma / ID channel dấu phẩy
AUTO_CHANNEL_SWITCH=false              # Rotate channels 5-6min / Đổi kênh 5-6 phút
AUTO_ISOLATE_CHANNEL=true              # Unique channel on start / Kênh riêng khi start
AUTO_SMART_ZOO=true                    # Auto-build battle team / Tự tạo team
AUTO_ACCEPT_RULES=true                 # Auto-click Accept Rules / Tự bấm Accept

# --- 9. MINI GAMES / CỜ BẠC ---
# ⚠️ Warning: fixed amount, no strategy — drains fast! / Đặt cố định, cạn tiền nhanh!
AUTO_GAMBLE_CF=false                   # owo cf 30-60s
AUTO_GAMBLE_CF_AMOUNT=1                # Bet amount / Số cowoncy đặt
AUTO_GAMBLE_CF_SIDE=h                  # h=heads (ngửa) t=tails (sấp)
AUTO_GAMBLE_SLOTS=false                # owo slots 25-50s
AUTO_GAMBLE_SLOTS_AMOUNT=1             # Bet amount / Số cowoncy đặt
AUTO_LEVEL_QUOTES=false                # Send quotes to level / Gửi câu lên level

# --- 10. RPP & SHOP ---
AUTO_RPP=false                         # owo run/pup/piku
RPP_COMMANDS=run,pup,piku              # RPP commands / Lệnh RPP
RPP_INTERVAL=60                        # Check interval sec / Chu kỳ giây
AUTO_SHOP=false                        # Auto-buy rings / Tự mua nhẫn
SHOP_ITEMS=                            # Ring IDs 1-7 (1=10cc, 7=10M) / ID nhẫn
SHOP_INTERVAL=3600                     # Check interval sec / Chu kỳ giây

# --- 11. DASHBOARD & DIAGNOSTICS ---
DASHBOARD=true                         # Terminal ASCII dashboard / Bảng terminal
DASHBOARD_PORT=3000                    # Web dashboard port / Port dashboard
TEST_MODE=false                        # Test mode (dev only) / Chế độ test (dev)

# --- 12. PROXY ---
USE_PROXY=false                        # Enable proxy / Bật proxy (cấu hình proxies.txt)
ACCOUNTS_PER_PROXY=1                   # Accounts per proxy / Số acc/proxy
PROXY_TIMEOUT=5000                     # Timeout ms / Chờ ms
