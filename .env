# ==============================================================================
# OwO Pro Farmer VIP — GLOBAL CONFIGURATION / CẤU HÌNH HỆ THỐNG
# ==============================================================================
# EN: true = ENABLE (ON) | false = DISABLE (OFF). Restart the tool to apply changes!
# VI: true = BẬT (Cho phép) | false = TẮT (Không cho phép). Khởi động lại tool để áp dụng!
# ==============================================================================

# --- 1. LICENSE & CAPTCHA (BẢN QUYỀN & CAPTCHA) ---
LICENSE_KEY=
CAPTCHA_API_KEY=
# EN: Auto resolve link captchas & image captchas
# VI: Tự động giải mã captcha link và hình ảnh
USE_AUTO_CAPTCHA_LINK=true
USE_AUTO_CAPTCHA_IMAGE=true
CAPTCHA_CONCURRENCY=2
CHROME_PATH=

# --- 2. WEBHOOK & NOTIFICATIONS (THÔNG BÁO DISCORD) ---
NOTIFY_BOT_TOKEN=
ADMIN_ID=
WEBHOOK_URL=
LOG_WEBHOOK_URL=

# --- 3. BASIC FARMING (CHẾ ĐỘ FARM CƠ BẢN) ---
# EN: Sleep cycle simulates real human sleep (rests 6-8 hours a day)
# VI: Chế độ mô phỏng ngủ thật của người dùng (nghỉ 6-8 tiếng mỗi ngày)
SLEEP_CYCLE=false
AUTO_HUNT=true
AUTO_PRAY=true
AUTO_CURSE=false
# EN: Comma-separated IDs for pray/curse. Leave blank for self.
# VI: Danh sách ID người dùng để pray/curse (cách nhau bằng dấu phẩy). Trống = tự buff bản thân.
CURSE_PRAY_TARGETS=
AUTO_DAILY=true

# --- 4. HUNTBOT (ROBOT ĐI SĂN) ---
AUTO_HUNTBOT=true
# EN: Auto upgrade huntbot with essence. Priority order below.
# VI: Tự động nâng cấp Huntbot bằng animal essence. Thứ tự ưu tiên ở dưới.
AUTO_HUNTBOT_UPGRADE=true
HUNTBOT_UPGRADE_PRIORITY=efficiency, gain, duration, cost, experience, radar
HUNTBOT_UPGRADE_MAX_LEVEL=1000

# --- 5. GEMS, INVENTORY & ITEMS (NGỌC, TÚI ĐỒ & VẬT PHẨM) ---
# EN: Auto equip gems. Specify custom gems IDs if needed.
# VI: Tự động trang bị ngọc. Danh sách ngọc bên dưới.
AUTO_USE_GEMS=true
CUSTOM_GEMS=51,52,53,54,55,56,57,65,66,67,68,69,70,71,72,73,74,75,76,77,78
# EN: Auto sell/sacrifice animals when inventory is full.
# VI: Tự động bán/hiến tế thú khi đầy kho.
AUTO_SELL=true
SELL_TYPE=all
AUTO_SACRIFICE=true
SACRIFICE_TYPE=all
# EN: Auto open weapon crates & lootboxes
# VI: Tự động mở hộp quà ngay khi nhận
AUTO_OPEN_BOXES=true

# --- 6. EXTRA AUTOMATION (CÁC TÍNH NĂNG PHỤ TRỢ) ---
AUTO_REPLY=false
AUTO_QUEST=false
AUTO_COOKIE=false
COOKIE_TARGET_ID=
AUTO_BOSS=false
BOSS_JOIN_CHANCE=100
AUTO_GIVEAWAY=false
GIVEAWAY_CHANNELS=
AUTO_CHANNEL_SWITCH=false
# EN: Smart Zoo creates the strongest battle team automatically
# VI: Smart Zoo tự động tạo Battle Team với các thú mạnh nhất
AUTO_SMART_ZOO=true
AUTO_ACCEPT_RULES=true

# --- 7. MINI GAMES (ĐÁNH BẠC / LEVELING) ---
AUTO_GAMBLE_CF=false
AUTO_GAMBLE_CF_AMOUNT=1
AUTO_GAMBLE_CF_SIDE=h
AUTO_GAMBLE_SLOTS=false
AUTO_GAMBLE_SLOTS_AMOUNT=1
AUTO_LEVEL_QUOTES=false

# --- 8. MISCELLANEOUS (KHÁC) ---
AUTO_RPP=false
RPP_COMMANDS=run,pup,piku
RPP_INTERVAL=60
AUTO_SHOP=false
SHOP_ITEMS=
SHOP_INTERVAL=3600
TYPING_SIMULATION=false
DASHBOARD=false
TEST_MODE=false